# Private key for deployment/configuration/upgrade broadcasts.
# Use a funded deployer key for deploy, then the owner key for owner-only scripts.
PRIVATE_KEY=

# Celo RPC endpoint. Verify the current official endpoint before mainnet use.
CELO_RPC_URL=

# Celo Mainnet is 42220. Use the target chain id for testnet/local deployments.
EXPECTED_CHAIN_ID=42220

# DeployArcelo.s.sol
ARCELO_OWNER=
BACKEND_SIGNER=
GENESIS_WEEK_START=
MAX_SESSION_DURATION=7200

# Arcelo supports USDC only. Values are raw USDC units.
USDC_TOKEN=
USDC_MIN_BET=
USDC_MAX_BET=

# ConfigureCeloMainnet.s.sol and UpgradeArcelo.s.sol
ARCELO_PROXY=
